{
  "schemaVersion": 1,
  "type": "loom-plugin",
  "name": "task-journal",
  "title": "Task Journal",
  "version": "0.1.0",
  "apiVersion": "1.0",
  "entry": "./dist/adapter.js",
  "provides": {
    "tabs": [{ "id": "tasks", "title": "Tasks" }],
    "actions": [
      { "id": "openTask", "label": "Open task" },
      { "id": "closeTask", "label": "Close task" },
      { "id": "writeTokenMetric", "label": "Write token metric" }
    ]
  },
  "install": {
    "install": [
      { "cmd": "fetch-release", "args": [],
        "fetchRelease": { "repo": "Digital-Threads/Task-Journal", "tag": "v0.28.3", "name": "task-journal", "bins": ["task-journal", "task-journal-mcp"] } },
      { "cmd": "claude", "args": ["plugin","marketplace","add","https://github.com/Digital-Threads/Task-Journal"] },
      { "cmd": "claude", "args": ["plugin","install","--scope","{scope}","task-journal@task-journal"], "scoped": true }
    ],
    "detect": { "probe": { "cmd": "claude", "args": ["plugin","list"] },
                "presenceMatch": "task-journal@task-journal",
                "latest": { "probe": { "cmd": "curl", "args": ["-fsSL","https://api.github.com/repos/Digital-Threads/Task-Journal/releases/latest"] }, "versionRegex": "\"tag_name\":\\s*\"v?([0-9.]+)\"" } },
    "remove": [
      { "cmd": "claude", "args": ["plugin","uninstall","task-journal@task-journal"] }
    ]
  }
}

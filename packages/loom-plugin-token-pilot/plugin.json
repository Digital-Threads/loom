{
  "schemaVersion": 1,
  "type": "loom-plugin",
  "name": "token-pilot",
  "title": "Token Pilot",
  "version": "0.1.0",
  "apiVersion": "1.0",
  "entry": "./dist/adapter.js",
  "provides": {
    "tabs": [{ "id": "tokens", "title": "Токены" }],
    "settings": true
  },
  "install": {
    "install": [
      { "cmd": "claude", "args": ["plugin","marketplace","add","https://github.com/Digital-Threads/token-pilot"] },
      { "cmd": "claude", "args": ["plugin","install","--scope","{scope}","token-pilot@token-pilot"], "scoped": true }
    ],
    "detect": { "probe": { "cmd": "claude", "args": ["plugin","list"] },
                "presenceMatch": "token-pilot@token-pilot" },
    "remove": [{ "cmd": "claude", "args": ["plugin","uninstall","token-pilot@token-pilot"] }]
  }
}

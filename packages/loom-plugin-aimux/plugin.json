{
  "schemaVersion": 1,
  "type": "loom-plugin",
  "name": "aimux",
  "title": "Aimux",
  "version": "0.1.0",
  "apiVersion": "1.0",
  "entry": "./dist/adapter.js",
  "provides": {
    "tabs": [
      { "id": "subscriptions", "title": "Подписки" },
      { "id": "sessions", "title": "Сессии" }
    ],
    "actions": [{ "id": "addSubscription", "label": "Добавить подписку" }]
  },
  "install": {
    "install": [{ "cmd": "npm", "args": ["install","-g","@digital-threads/aimux"] }],
    "detect": { "probe": { "cmd": "npm", "args": ["ls","-g","@digital-threads/aimux"] },
                "versionRegex": "@digital-threads/aimux@([0-9.]+)",
                "latest": { "probe": { "cmd": "npm", "args": ["view","@digital-threads/aimux","version"] } } },
    "remove": [{ "cmd": "npm", "args": ["uninstall","-g","@digital-threads/aimux"] }]
  }
}
